# At least one AI provider API key is required.
# The first available model will be used as default.

# Groq (free tier, fast inference)
GROQ_API_KEY=

# Google Gemini (free tier)
GEMINI_API_KEY=

# OpenAI (paid, per-token)
OPENAI_API_KEY=

# OpenAI (ChatGPT subscription via OAuth token — run scripts/openai-login.ts to get one)
OPENAI_OAUTH_TOKEN=
OPENAI_REFRESH_TOKEN=
OPENAI_TOKEN_EXPIRATION_IN_HOURS=240

# Anthropic (paid)
ANTHROPIC_API_KEY=

# Required: which provider to use
# Valid values: groq, gemini, openai, openai-oauth, anthropic
LLM_PROVIDER=openai

# Required: which model to use
LLM_MODEL=gpt-5.4

# Server
PORT=5040
BROWSER_INTERNAL_TOKEN=

# Browser
BROWSER_HEADLESS=false
SSRF_ALLOW_PRIVATE=false

# Rate limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=86400000

# MinIO (skill catalog storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=browserclaw-skills

# Session limits
MAX_SESSIONS=10
SESSION_IDLE_TIMEOUT_MS=900000

# Agent timing (ms)
MAX_STEPS=200
WAIT_AFTER_TYPE_MS=2000
WAIT_AFTER_CLICK_MS=1000
WAIT_AFTER_OTHER_MS=500
WAIT_ACTION_MS=2000
USER_RESPONSE_TIMEOUT_MS=300000

# Prompt logging
PROMPT_LOG_DIR=/app/data/prompts
